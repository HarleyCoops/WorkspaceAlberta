# Workspace Alberta Hermes local API server
# Copy this into the active Hermes .env file if you are configuring manually.
# Do not put real API keys or OAuth tokens in this repo.

API_SERVER_ENABLED=true
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8642
API_SERVER_MODEL_NAME=hermes-agent

# Add provider keys locally, never in git, for example:
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
